generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships OrganizationMembership[]
  activityLogs ActivityLog[]
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  niche       String   @default("antique-vintage-jewelry")
  brandConfig String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships        OrganizationMembership[]
  inventoryItems     InventoryItem[]
  inventoryPhotos    InventoryPhoto[]
  inventoryDocuments InventoryDocument[]
  inventoryTags      InventoryTag[]
  tags               Tag[]
  storageLocations   StorageLocation[]
  marketplaceAccounts MarketplaceAccount[]
  marketplaceListings MarketplaceListing[]
  marketplaceAuthorizations MarketplaceAuthorization[]
  listingTemplates   ListingTemplate[]
  orders             Order[]
  orderItems          OrderItem[]
  transactions       Transaction[]
  expenses           Expense[]
  syncEvents         SyncEvent[]
  activityLogs       ActivityLog[]
  actionAlertStates  ActionAlertState[]
  analyticsSnapshots AnalyticsSnapshot[]
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           String   @default("Owner")
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, status])
}

model InventoryItem {
  id                    String   @id @default(uuid())
  organizationId        String
  sku                   String
  title                 String
  description           String   @default("")
  category              String   @default("Other")
  type                  String   @default("Unknown")
  estimatedEra          String?
  brand                 String?
  metalType             String?
  metalPurity           String?
  gemstoneType          String?
  gemstoneColor         String?
  ringSize              String?
  dimensions            String?
  weight                String?
  condition             String   @default("Good")
  conditionNotes        String?
  restorationHistory    String?
  authenticityNotes     String?
  purchaseSource        String?
  purchaseDate          DateTime?
  purchaseCost          Float?
  restorationCost       Float?   @default(0)
  cleaningCost          Float?   @default(0)
  appraisalCost         Float?   @default(0)
  packagingCost         Float?   @default(0)
  shippingCost          Float?   @default(0)
  totalCostBasis        Float?
  askingPrice           Float?
  minAcceptablePrice    Float?
  currentMarketplacePrice Float?
  storageLocationId     String?
  status                String   @default("Draft")
  dateListed            DateTime?
  daysInInventory       Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storageLocation  StorageLocation?  @relation(fields: [storageLocationId], references: [id])
  photos           InventoryPhoto[]
  documents        InventoryDocument[]
  tags             InventoryTag[]
  marketplaceListings MarketplaceListing[]
  orderItems       OrderItem[]
  transactions     Transaction[]
  expenses         Expense[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@unique([organizationId, sku])
  @@index([organizationId, status])
}

model InventoryPhoto {
  id             String @id @default(uuid())
  organizationId String
  inventoryItemId String
  filename        String
  originalName    String
  mimeType        String
  isPrimary       Boolean @default(false)
  sortOrder       Int     @default(0)
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, inventoryItemId])
}

model InventoryDocument {
  id             String @id @default(uuid())
  organizationId String
  inventoryItemId String
  filename        String
  originalName    String
  documentType    String?
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, inventoryItemId])
}

model Tag {
  id             String @id @default(uuid())
  organizationId String
  name           String
  color          String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItems InventoryTag[]

  @@unique([organizationId, name])
}

model InventoryTag {
  organizationId String
  inventoryItemId String
  tagId          String

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  tag           Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([inventoryItemId, tagId])
  @@index([organizationId])
}

model StorageLocation {
  id             String   @id @default(uuid())
  organizationId String
  code           String
  name           String
  room           String?
  cabinet        String?
  shelf          String?
  drawer         String?
  tray           String?
  box            String?
  slot           String?
  qrCode         String?
  parentId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       StorageLocation?  @relation("StorageHierarchy", fields: [parentId], references: [id])
  children     StorageLocation[] @relation("StorageHierarchy")
  items        InventoryItem[]

  @@unique([organizationId, code])
}


model MarketplaceAuthorization {
  id             String   @id @default(uuid())
  organizationId String
  marketplace    String
  state          String   @unique
  codeVerifier   String?
  redirectUri    String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, marketplace, expiresAt])
}

model MarketplaceAccount {
  id                    String   @id @default(uuid())
  organizationId        String
  marketplace           String
  accountName           String
  isConnected           Boolean  @default(false)
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  storeName             String?
  storeId               String?
  lastSyncAt            DateTime?
  syncStatus            String   @default("Idle")
  syncErrorMessage      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listings     MarketplaceListing[]
  orders       Order[]

  @@unique([organizationId, marketplace, storeId])
  @@index([organizationId, marketplace, isConnected])
}

model MarketplaceListing {
  id                    String   @id @default(uuid())
  organizationId        String
  inventoryItemId       String
  marketplaceAccountId  String?
  marketplace           String
  marketplaceListingId  String?
  marketplaceListingUrl String?
  title                 String
  description           String?
  price                 Float
  quantity              Int      @default(1)
  status                String   @default("Draft")
  marketplaceCategory   String?
  shippingProfile       String?
  returnPolicy          String?
  tags                  String?
  photoOrder            String?
  etsySpecificFields    String?
  ebaySpecificFields    String?
  lastSyncAt            DateTime?
  syncStatus            String   @default("Pending")
  syncMessage           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem      InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  marketplaceAccount MarketplaceAccount? @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)

  @@unique([marketplaceAccountId, marketplaceListingId])
  @@index([organizationId, inventoryItemId, marketplace, status])
}

model ListingTemplate {
  id                  String @id @default(uuid())
  organizationId      String
  name                String
  category            String
  titleTemplate       String?
  descriptionTemplate String?
  tagsTemplate        String?
  shippingProfile     String?
  returnPolicy        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

model Order {
  id                   String   @id @default(uuid())
  organizationId       String
  marketplaceAccountId String?
  orderNumber          String
  marketplace          String
  marketplaceOrderId   String?
  buyerName            String?
  buyerUsername        String?
  buyerEmail           String?
  saleDate             DateTime
  paymentStatus        String   @default("Pending")
  fulfillmentStatus    String   @default("AwaitingPayment")
  shippingDeadline     DateTime?
  shippingCarrier      String?
  trackingNumber       String?
  shippingCost         Float?   @default(0)
  insuranceCost        Float?   @default(0)
  salesTaxCollected    Float?   @default(0)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  marketplaceAccount MarketplaceAccount? @relation(fields: [marketplaceAccountId], references: [id], onDelete: SetNull)
  orderItems          OrderItem[]
  transactions        Transaction[]

  @@unique([marketplaceAccountId, marketplaceOrderId])
  @@index([organizationId, saleDate])
}

model OrderItem {
  id             String @id @default(uuid())
  organizationId String
  orderId         String
  inventoryItemId String
  salePrice       Float
  quantity        Int    @default(1)
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([organizationId, orderId])
}

model Transaction {
  id              String   @id @default(uuid())
  organizationId  String
  type            String
  category        String?
  orderId         String?
  inventoryItemId String?
  amount          Float
  description     String?
  transactionDate DateTime
  marketplace     String   @default("Manual")
  vendor          String?
  paymentMethod   String?
  receiptFilename String?
  createdAt       DateTime @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order?         @relation(fields: [orderId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([organizationId, transactionDate])
}

model Expense {
  id              String   @id @default(uuid())
  organizationId  String
  category        String
  vendor          String?
  amount          Float
  expenseDate     DateTime
  paymentMethod   String?
  receiptFilename String?
  inventoryItemId String?
  notes           String?
  createdAt       DateTime @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([organizationId, expenseDate])
}

model SyncEvent {
  id               String   @id @default(uuid())
  organizationId   String
  marketplace      String
  eventType        String
  status           String
  message          String?
  relatedItemId    String?
  relatedListingId String?
  retryCount       Int      @default(0)
  lastAttemptAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ActivityLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String
  details        String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
}


model ActionAlertState {
  id             String   @id @default(uuid())
  organizationId String
  alertId        String
  dismissed      Boolean  @default(false)
  snoozedUntil   DateTime?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, alertId])
  @@index([organizationId, snoozedUntil])
}

model AnalyticsSnapshot {
  id                   String   @id @default(uuid())
  organizationId       String
  inventoryItemId      String
  marketplaceListingId String?
  views                Int?     @default(0)
  favorites            Int?     @default(0)
  watchers             Int?     @default(0)
  clicks               Int?     @default(0)
  conversions          Int?     @default(0)
  score                Float?
  snapshotDate         DateTime
  createdAt            DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([organizationId, snapshotDate])
}
